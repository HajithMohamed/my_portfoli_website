{
  "extends": "./tsconfig.json",
  // `prisma` is excluded so `src` is the only compiled root: TypeScript then emits
  // dist/main.js rather than dist/src/main.js, which is what `start:prod` runs.
  // prisma/seed.ts is executed through ts-node, so it never needs compiling.
  "exclude": ["node_modules", "test", "dist", "prisma", "**/*spec.ts"]
}
