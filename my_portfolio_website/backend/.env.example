PORT=4000
FRONTEND_URL=http://localhost:3000
NETLIFY_URL=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hz_labs?schema=public
# --- Hidden admin (single administrator, credentials live only in env) ---
ADMIN_EMAIL=admin@hzlabs.dev
# Either set a plaintext password (simple) ...
ADMIN_PASSWORD=ChangeMe123!
# ... or, preferred, an argon2 hash (leave ADMIN_PASSWORD unset if you use this):
# ADMIN_PASSWORD_HASH=
ADMIN_NAME=Mohamed Hajith
# Long random string used to sign the session JWT.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
# Session cookie lifetime in minutes (how long a login stays valid).
ADMIN_SESSION_TTL_MINUTES=120
GITHUB_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
