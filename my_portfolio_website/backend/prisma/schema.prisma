generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum AssetType {
  IMAGE
  CV
  DOCUMENT
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          Role           @default(ADMIN)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Profile {
  id                 String       @id @default(cuid())
  name               String
  title              String
  tagline            String
  bio                String
  philosophy         String
  location           String
  email              String
  availabilityStatus String
  profileImageUrl    String?
  currentlyExploring String[]
  timeline           Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  socialLinks        SocialLink[]
}

model SocialLink {
  id        String  @id @default(cuid())
  label     String
  url       String
  icon      String?
  order     Int     @default(0)
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, label])
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String
  icon        String?
  proficiency Int      @default(80)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, category])
}

model Project {
  id          String             @id @default(cuid())
  title       String
  slug        String             @unique
  description String
  techStack   String[]
  githubUrl   String?
  liveUrl     String?
  coverImage  String?
  category    String
  status      ProjectStatus      @default(DRAFT)
  featured    Boolean            @default(false)
  outcome     String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  media       ProjectMedia[]
  caseStudy   CaseStudySection[]
}

model ProjectMedia {
  id        String    @id @default(cuid())
  url       String
  alt       String
  type      AssetType @default(IMAGE)
  order     Int       @default(0)
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CaseStudySection {
  id        String  @id @default(cuid())
  heading   String
  body      String
  order     Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String
  content     String
  coverImage  String?
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tags        BlogTag[]
}

model BlogTag {
  id    String     @id @default(cuid())
  name  String
  slug  String     @unique
  posts BlogPost[]
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CvAsset {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String
  publicId  String?
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GithubSnapshot {
  id               String   @id @default(cuid())
  username         String
  repositoryCount  Int      @default(0)
  commitCount      Int      @default(0)
  languages        Json
  recentRepos      Json
  recentActivity   Json
  contributionData Json?
  syncedAt         DateTime @default(now())
}

model SyncSuggestion {
  id        String           @id @default(cuid())
  source    String
  title     String
  payload   Json
  status    SuggestionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

/// One visitor session (30-minute sliding window, keyed by a client-generated
/// sessionKey). Enriched server-side with device/OS/browser (user agent),
/// country/region/city (IP geolocation), and traffic source (referrer/UTM).
model VisitorSession {
  id             String           @id @default(cuid())
  sessionKey     String           @unique
  visitorId      String
  startedAt      DateTime         @default(now())
  lastSeenAt     DateTime         @default(now())
  entryPath      String?
  exitPath       String?
  referrer       String?
  source         String           @default("Direct")
  device         String           @default("desktop")
  os             String?
  browser        String?
  country        String?
  countryCode    String?
  region         String?
  city           String?
  isReturning    Boolean          @default(false)
  pageViewCount  Int              @default(0)
  maxScrollDepth Int              @default(0)
  pageViews      PageView[]
  events         AnalyticsEvent[]

  @@index([startedAt])
  @@index([lastSeenAt])
  @@index([visitorId])
}

model PageView {
  id          String         @id @default(cuid())
  path        String
  duration    Int            @default(0)
  scrollDepth Int            @default(0)
  createdAt   DateTime       @default(now())
  sessionId   String
  session     VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
}

model AnalyticsEvent {
  id        String          @id @default(cuid())
  type      String
  path      String?
  metadata  Json?
  createdAt DateTime        @default(now())
  sessionId String?
  session   VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
}

/// Security audit trail for the hidden admin surface: logins (success/failure),
/// logout, and privileged actions, with the originating IP and user agent.
model AdminActivityLog {
  id        String   @id @default(cuid())
  action    String
  success   Boolean  @default(true)
  ip        String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

/// Uploaded personal photos / imagery (Cloudinary). category: profile | gallery | about.
model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  alt       String   @default("")
  category  String   @default("gallery")
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([category])
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String?
  company   String?
  quote     String
  avatarUrl String?
  project   String?
  rating    Int      @default(5)
  featured  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
}

/// Certifications and achievements. type: certification | achievement.
model Certificate {
  id            String    @id @default(cuid())
  title         String
  issuer        String
  type          String    @default("certification")
  issueDate     DateTime?
  credentialUrl String?
  imageUrl      String?
  order         Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([type])
}
